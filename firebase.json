{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".git/**",
      ".agent/**",
      "app.js",
      "deploy.bat",
      "style.css",
      "product-detail.html",
      "index.html",
      "shop.html"
    ],
    "redirects": [
      {
        "source": "/index.html",
        "destination": "/",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          },
          {
            "key": "Vary",
            "value": "Accept-Encoding"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|ico|svg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(woff|woff2|ttf|otf)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/getHomeData",
        "function": "getHomeData"
      },
      {
        "source": "/p/**",
        "function": "renderProduct"
      },
      {
        "source": "/product-detail.html",
        "function": "renderProduct"
      },
      {
        "source": "/",
        "function": "renderHome"
      },
      {
        "source": "/shop",
        "function": "renderShop"
      },
      {
        "source": "/shop.html",
        "function": "renderShop"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}