rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if anyone is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user is the Admin (Shop Owner)
    // Replace "laszonaicreation@gmail.com" with your actual Google login email!
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "laszonaicreation@gmail.com";
    }

    // 1. Products, Categories, Menus: Public Read, ONLY ADMIN Can Write/Edit
    match /artifacts/{anyAppId}/public/data/products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /artifacts/{anyAppId}/public/data/categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /artifacts/{anyAppId}/public/data/sliders/{sliderId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /artifacts/{anyAppId}/public/data/mega_menus/{menuId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /artifacts/{anyAppId}/public/data/popupSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Leads (Customer Data): Public Create, ONLY ADMIN Can Read/Delete
    match /artifacts/{anyAppId}/public/data/leads/{leadId} {
      allow create: if true; 
      allow read, update, delete: if isAdmin();
    }

    // 3. Wishlists & Cart: Only the owner can read/write their own data
    match /artifacts/{anyAppId}/users/{userId}/data/wishlist {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    match /artifacts/{anyAppId}/users/{userId}/data/cart {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 4. Shared Selections
    match /artifacts/{anyAppId}/public/data/selections/{selectionId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // 5. Stats & Tracking: Open purely for tracking scripts
    match /artifacts/{anyAppId}/public/data/products/_ad_stats_ {
      allow read: if true;
      allow write: if true; 
    }
    match /artifacts/{anyAppId}/public/data/daily_stats/{dateId} {
      allow read: if true;
      allow write: if true; 
    }
    match /artifacts/{anyAppId}/public/data/daily_product_stats/{statId} {
      allow read: if true;
      allow write: if true;
    }

    // 6. Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
